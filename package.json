{
  "name": "template",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "node scripts/install-hooks.mjs",
    "typecheck": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "precommit:check": "npm run typecheck && npm run lint && npm run test && npm run knip",
    "hooks:install": "node scripts/install-hooks.mjs",
    "validate": "npm run typecheck && npm run lint && npm run test && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@lottiefiles/dotlottie-web": "^0.71.0",
    "@lucide/astro": "^1.8.0",
    "astro": "^6.1.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "jsdom": "^26.1.0",
    "knip": "^6.4.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.2.4"
  }
}
