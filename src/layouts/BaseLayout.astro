---
import Footer from '../components/layout/Footer.astro';
import Navbar from '../components/layout/Navbar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  hideChrome?: boolean;
}

const { title, description = '', hideChrome = false } = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
      // Restore saved theme before first paint to prevent FOUC.
      // Falls back to the server-rendered data-theme="dark" default.
      const _saved = localStorage.getItem('site-theme');
      if (_saved) document.documentElement.dataset.theme = _saved;
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0d1117" />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    {!hideChrome && <Navbar />}
    <main id="main-content" tabindex="-1" class="page-main">
      <slot />
    </main>
    {!hideChrome && <Footer />}
    <script>
      // ── Scroll-triggered fade-in via IntersectionObserver ──────────────
      // A single observer watches all .fade-up elements and adds .is-visible
      // when they enter the viewport. The CSS transition (in global.css) is
      // gated on prefers-reduced-motion: no-preference, so users who prefer
      // reduced motion see content immediately with no transition.
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          // rootMargin -10% on the bottom shrinks the trigger zone so an element
          // begins fading before it's fully in view — avoids the jarring snap
          // you get with threshold:0 (fires the moment one pixel enters).
          { rootMargin: '0px 0px -10% 0px' },
        );
        document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
