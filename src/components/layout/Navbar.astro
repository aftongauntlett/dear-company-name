---
import { APPLICANT } from '../../config/site';
import ThemePicker from './ThemePicker.astro';
import Icon from '../ui/Icon.astro';
import { Menu, X } from '@lucide/astro';

const nav = [
  { href: '#start', label: 'How I Start' },
  { href: '#stack', label: 'How I Choose a Stack' },
  { href: '#ai', label: 'How I Use AI' },
  { href: '#how-i-work', label: 'How I Work' },
  { href: '#teams', label: 'Team Impact' },
  { href: '#looking-for', label: "What I'm Looking For" },
];

const currentPath = Astro.url.pathname;
const isHomePage = currentPath === '/';
---

<header class="site-header" id="site-header">
  <div class="site-header-inner container">
    <a href={isHomePage ? '#top' : '/'} class="brand" aria-label={isHomePage ? 'Back to top' : 'Home'}>
      <span class="brand-name">{APPLICANT.name}</span>
    </a>

    <nav id="primary-nav" aria-label="Primary" class="site-nav">
      <ul>
        {nav.map((item) => {
          const isAnchor = item.href.startsWith('#');
          const isPageLink = !isAnchor;
          const resolvedHref = isAnchor && !isHomePage ? `/${item.href}` : item.href;
          const isCurrentPage = isPageLink && currentPath === item.href;
          return (
            <li>
              <a
                href={resolvedHref}
                data-nav-href={isAnchor && isHomePage ? item.href : undefined}
                aria-current={isCurrentPage ? 'page' : undefined}
                class:list={[{ 'is-active': isCurrentPage }]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="header-end">
      <ThemePicker />
      <button
        id="nav-toggle"
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="primary-nav"
        aria-label="Open navigation menu"
      >
        <span class="nav-toggle-icon nav-toggle-icon--open" aria-hidden="true">
          <Icon icon={Menu} size={20} />
        </span>
        <span class="nav-toggle-icon nav-toggle-icon--close" aria-hidden="true">
          <Icon icon={X} size={20} />
        </span>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    // ── Active nav via IntersectionObserver ───────────────────────
    const links = Array.from(
      document.querySelectorAll('.site-nav a[data-nav-href]')
    );

    let activeId = '';

    function setActive(id) {
      if (id === activeId) return;
      activeId = id;
      links.forEach((a) => {
        const isActive = a.getAttribute('data-nav-href') === '#' + id;
        a.classList.toggle('is-active', isActive);
        a.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    }

    // ── Brand link: smooth scroll to top without adding #top to URL ────
    const brandLink = document.querySelector('.brand[href="#top"]');
    if (brandLink) {
      brandLink.addEventListener('click', (e) => {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
        history.replaceState(null, '', window.location.pathname);
      });
    }

    // ── Immediate active on click ─────────────────────────────────
    links.forEach((a) => {
      a.addEventListener('click', () => {
        const id = a.getAttribute('data-nav-href')?.replace('#', '');
        if (id) setActive(id);
      });
    });

    // ── IntersectionObserver for scroll-based active ──────────────
    // Must wait for DOMContentLoaded: this script runs before <main> sections
    // are parsed, so getElementById returns null if called immediately.
    if ('IntersectionObserver' in window && links.length > 0) {
      document.addEventListener('DOMContentLoaded', function () {
        const sectionIds = links
          .map((a) => a.getAttribute('data-nav-href')?.replace('#', ''))
          .filter(Boolean);

        const sections = sectionIds
          .map((id) => document.getElementById(id))
          .filter(Boolean);

        if (sections.length > 0) {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) setActive(entry.target.id);
              });
            },
            { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
          );

          sections.forEach((s) => observer.observe(s));
        }
      });
    }

    // ── Hamburger toggle ──────────────────────────────────────────
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('nav-toggle');
    const navEl  = document.getElementById('primary-nav');

    if (!(header && toggle && navEl)) return;

    function openNav() {
      header.classList.add('nav-open');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close navigation menu');
    }

    function closeNav() {
      header.classList.remove('nav-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open navigation menu');
    }

    toggle.addEventListener('click', () => {
      if (header.classList.contains('nav-open')) {
        closeNav();
      } else {
        openNav();
      }
    });

    // Close when a nav link is tapped
    navEl.addEventListener('click', (e) => {
      if (e.target instanceof HTMLAnchorElement) closeNav();
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (header.classList.contains('nav-open') && !header.contains(e.target)) {
        closeNav();
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.classList.contains('nav-open')) {
        closeNav();
        toggle.focus();
      }
    });
  })();
</script>
