---
import { APPLICANT } from '../../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-inner container">
    <p class="footer-copy">&copy; {year} {APPLICANT.name}</p>

    <nav aria-label="Footer links" class="footer-links">
      <ul>
        <li>
          <a href={APPLICANT.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        </li>
        <li>
          <a href={APPLICANT.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </li>
        <li>
          <a href={APPLICANT.resume} target="_blank" rel="noopener noreferrer">R&eacute;sum&eacute;</a>
        </li>
      </ul>
    </nav>
  </div>
</footer>
