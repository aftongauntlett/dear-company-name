---
import { APPLICANT } from '../../config/site';
import BrandIcon from '../ui/BrandIcon.astro';
import Icon from '../ui/Icon.astro';
import { FileText, Mail, ArrowUp, Globe } from '@lucide/astro';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-inner container">

    <div class="footer-brand">
      <p class="footer-name">{APPLICANT.name}</p>
      <p class="footer-role">{APPLICANT.title}</p>
    </div>

    <nav aria-label="Footer links" class="footer-social">
      <ul role="list">
        <li>
          <a
            href={APPLICANT.github}
            class="footer-icon-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub profile"
            title="GitHub"
          >
            <BrandIcon name="github" size={18} />
          </a>
        </li>
        <li>
          <a
            href={APPLICANT.linkedin}
            class="footer-icon-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn profile"
            title="LinkedIn"
          >
            <BrandIcon name="linkedin" size={18} />
          </a>
        </li>
        <li>
          <a
            href={APPLICANT.website}
            class="footer-icon-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Portfolio website"
            title="Portfolio"
          >
            <Icon icon={Globe} size={18} />
          </a>
        </li>
        <li>
          <a
            href={APPLICANT.resume}
            class="footer-icon-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View résumé"
            title="Résumé"
          >
            <Icon icon={FileText} size={18} />
          </a>
        </li>
        <li>
          <a
            href={`mailto:${APPLICANT.email}`}
            class="footer-icon-link"
            aria-label="Send email"
            title={APPLICANT.email}
          >
            <Icon icon={Mail} size={18} />
          </a>
        </li>
      </ul>
    </nav>

  </div>

  <div class="footer-bottom container">
    <p class="footer-copy">© {year} {APPLICANT.name}</p>
    <a href={`mailto:${APPLICANT.email}`} class="footer-email-link">{APPLICANT.email}</a>
    <a href="#top" class="footer-back-to-top" aria-label="Back to top">
      <Icon icon={ArrowUp} size={14} aria-hidden="true" />
      Back to top
    </a>
  </div>
</footer>

<script is:inline>
  (function () {
    const btn = document.querySelector('.footer-back-to-top');
    if (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
        history.replaceState(null, '', window.location.pathname);
      });
    }
  })();
</script>
