---
import { THEMES } from '../../config/site';
import Icon from '../ui/Icon.astro';
import { Palette } from '@lucide/astro';

const themes = [...THEMES];
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Switch color theme"
  title="Switch color theme"
  data-themes={themes.join(',')}
>
  <Icon icon={Palette} size={18} />
</button>

<script is:inline>
  (function () {
    const key = 'site-theme';
    const btn = document.getElementById('theme-toggle');
    if (!(btn instanceof HTMLButtonElement)) return;

    const themes = (btn.dataset.themes ?? '').split(',').filter(Boolean);
    if (themes.length === 0) return;

    let saved = null;
    try { saved = localStorage.getItem(key); } catch { /* storage unavailable */ }
    const current = document.documentElement.dataset.theme ?? '';
    const initial =
      saved && themes.includes(saved)
        ? saved
        : themes.includes(current)
          ? current
          : themes[0];

    document.documentElement.dataset.theme = initial;

    btn.addEventListener('click', () => {
      const idx = themes.indexOf(document.documentElement.dataset.theme ?? '');
      const next = themes[(idx + 1) % themes.length];
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem(key, next); } catch { /* storage unavailable */ }
      btn.setAttribute('aria-label', `Switch color theme (current: ${next})`);
    });

    btn.setAttribute('aria-label', `Switch color theme (current: ${initial})`);
  })();
</script>
