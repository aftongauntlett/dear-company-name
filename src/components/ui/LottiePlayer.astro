---
/**
 * LottiePlayer — canvas-based dotlottie animation, theme-aware via CSS filter.
 * Loaded post-`window.load` to keep DotLottie + WASM off the critical path.
 * Dispatch `lottie:stop` on document to stop all active instances.
 */
interface Props {
  src: string;
  class?: string;
  width?: number | string;
  height?: number | string;
}

const { src, class: className, width, height } = Astro.props;
---

<canvas
  class:list={['lottie-canvas', className]}
  data-src={src}
  aria-hidden="true"
  role="presentation"
  style={`${width ? `width:${typeof width === 'number' ? `${width}px` : width};` : ''}${height ? `height:${typeof height === 'number' ? `${height}px` : height};` : ''}`}
></canvas>

<script>
  // Deferred post-load: keeps DotLottie + WASM out of the critical path.
  const initLottie = async () => {
    const canvases = document.querySelectorAll<HTMLCanvasElement>('.lottie-canvas');
    if (canvases.length === 0) return;

    const { DotLottie } = await import('@lottiefiles/dotlottie-web');

    canvases.forEach((canvas) => {
      const src = canvas.dataset.src;
      if (!src) return;

      new DotLottie({ canvas, src, autoplay: true, loop: true });

      const applyThemeFilter = () => {
        const isDark = (document.documentElement.dataset.theme ?? '') === 'dark';
        canvas.style.filter = isDark ? 'brightness(1.15) saturate(1.1)' : 'none';
      };

      applyThemeFilter();

      const themeObserver = new MutationObserver(applyThemeFilter);
      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme'],
      });
    });
  };

  if (document.readyState === 'complete') {
    initLottie();
  } else {
    window.addEventListener('load', initLottie, { once: true });
  }
</script>

<style>
  .lottie-canvas {
    display: block;
    width: 100%;
    height: 100%;
    transition: filter 200ms ease;
  }
</style>
