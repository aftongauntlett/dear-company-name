---
import Icon from './Icon.astro';

// eslint-disable-next-line @typescript-eslint/no-explicit-any
type LucideComponent = (props: any) => any;

interface Props {
  title: string;
  icon?: LucideComponent;
}

const { title, icon } = Astro.props;
---

<article class="setup-card">
  {icon && (
    <div class="setup-card-icon-wrap">
      <Icon icon={icon} size={22} class="setup-card-icon" />
    </div>
  )}
  <h3 class="setup-card-title">{title}</h3>
  <div class="setup-card-body">
    <slot />
  </div>
</article>

<style>
  .setup-card {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--tone-surface);
    border: 1px solid var(--tone-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-surface);
    transition: border-color 180ms ease;
  }

  .setup-card:hover {
    border-color: color-mix(in srgb, var(--tone-primary) 40%, var(--tone-border));
  }

  .setup-card-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--tone-primary) 12%, transparent);
    margin-block-end: var(--space-2);
  }

  .setup-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    font-weight: 700;
    color: var(--tone-text);
    margin: 0;
    line-height: 1.2;
  }

  .setup-card-body {
    color: var(--tone-text-muted);
    line-height: 1.65;
  }

  .setup-card-body p {
    margin: 0;
  }

  :global(.setup-card-icon) {
    color: var(--tone-primary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .setup-card:hover :global(.setup-card-icon) {
      animation: wiggle 0.5s ease-in-out;
    }
  }

  @media (max-width: 540px) {
    .setup-card-icon-wrap {
      display: none;
    }
  }
</style>
