---
import { Image } from 'astro:assets';
import { COMPANY } from '../../config/site';
import Button from '../ui/Button.astro';
import headshotImg from '../../assets/images/afton-headshot.png';
import littleAftonImg from '../../assets/images/little-afton.webp';

// The placeholder is always the "joke" text the animation types first.
// Hardcoded so the gag works even when targetName is already the real company.
const PLACEHOLDER_NAME = 'Company';
---

<section id="top" class="hero" aria-label="Introduction">
  <div class="container hero-container">

    {/* ── Left: headshot ───────────────────────────────────────── */}
    <div class="hero-image-col fade-up" style="--fade-delay: 0" aria-hidden="true">
      <div class="hero-image-wrap" id="hero-img-wrap">
        <div class="hero-img-container" id="hero-img-container">
          <Image
            src={headshotImg}
            alt="Afton Gauntlett professional headshot"
            class="hero-photo hero-photo--pro"
            widths={[380, 760, 1140]}
            sizes="585px"
            quality={90}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            draggable="false"
          />
          <Image
            src={littleAftonImg}
            alt="Young Afton, circa early-90s"
            class="hero-photo hero-photo--little"
            widths={[380, 760]}
            sizes="380px"
            loading="lazy"
            decoding="async"
            draggable="false"
          />
        </div>
        <p class="hero-photo-caption">
          <span class="hero-caption-text" id="hero-caption-text"></span>
        </p>
      </div>
    </div>

    {/* ── Right: text content ──────────────────────────────────── */}
    <div class="hero-content fade-up" style="--fade-delay: 1">
      {/* Accessible, always-present H1 — screen reader source of truth */}
      <h1 class="hero-headline">Dear {COMPANY.targetName},</h1>

      {/* Visual typewriter overlay — aria-hidden, never read by AT */}
      <p class="hero-headline hero-typewriter" aria-hidden="true">
        Dear <span class="hero-bracket">[</span><span
          class="typewriter-target"
          data-target={COMPANY.targetName}
          data-placeholder={PLACEHOLDER_NAME}></span><span class="hero-bracket">]</span>,
      </p>

      <p class="hero-subhead">
        I built this instead of recording a video. I hope this gives you a better sense of who I am and what I can bring to your team.
      </p>

      <div class="hero-cta">
        <Button href="#how-i-work">Learn more</Button>
        <Button href="#looking-for" variant="outline">Let's talk</Button>
      </div>
    </div>

  </div>

</section>

<style>
  /* ─── Section ────────────────────────────────────────────────── */

  .hero {
    position: relative;
    min-height: 70dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: var(--space-12);
  }

  /* ─── Two-column grid ────────────────────────────────────────── */

  .hero-container {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.35fr);
    gap: var(--space-16);
    align-items: center;
  }

  /* ─── Image column ───────────────────────────────────────────── */

  .hero-image-col {
    display: flex;
    justify-content: center;
  }

  /* ─── Headshot wrap + image swap ─────────────────────────────── */

  .hero-image-wrap {
    width: 100%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-img-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 2px 24px color-mix(in srgb, var(--tone-text) 10%, transparent);
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    transition: opacity 1.5s ease;
    user-select: none;
    -webkit-user-drag: none;
  }

  .hero-photo--pro {
    opacity: 1;
  }

  .hero-photo--little {
    opacity: 0;
  }

  .hero-img-container.is-little-afton .hero-photo--pro {
    opacity: 0;
  }

  .hero-img-container.is-little-afton .hero-photo--little {
    opacity: 1;
  }

  /* ─── Hover caption / easter-egg text ────────────────────────── */

  .hero-photo-caption {
    min-height: 5rem;
    font-size: 0.875rem;
    color: var(--tone-text-muted);
    line-height: 1.6;
    font-style: italic;
    text-align: center;
  }

  .hero-caption-text.is-active::after {
    content: '|';
    color: var(--tone-primary);
    animation: caption-caret-blink 0.7s step-end infinite;
  }

  @keyframes caption-caret-blink {
    50% {
      opacity: 0;
    }
  }

  /* ─── Content column ─────────────────────────────────────────── */

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* ─── Headline shared styles ─────────────────────────────────── */

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 4.4rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--tone-text);
    margin: 0;
  }

  /* ─── Typewriter overlay (default: hidden, no-JS safe) ───────── */

  .hero-typewriter {
    display: none;
  }

  /* ─── With JS: visually hide real H1, show overlay ───────────── */

  :global(.js) .hero-headline:not(.hero-typewriter) {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  :global(.js) .hero-typewriter {
    display: block;
  }

  /* ─── Bracket styling ────────────────────────────────────────── */

  .hero-bracket {
    color: var(--tone-text-muted);
  }

  /* ─── Typing caret ───────────────────────────────────────────── */

  .typewriter-target::after {
    content: '|';
    color: var(--tone-primary);
    animation: hero-caret-blink 0.7s step-end infinite;
  }

  @keyframes hero-caret-blink {
    50% {
      opacity: 0;
    }
  }

  /* ─── Subheadline ────────────────────────────────────────────── */

  .hero-subhead {
    font-size: 1.15rem;
    color: var(--tone-text-muted);
    max-width: 38rem;
    line-height: 1.65;
  }

  /* ─── CTA cluster ────────────────────────────────────────────── */

  .hero-cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
  }

  /* ─── Mobile: single column, image on top ────────────────────── */

  @media (max-width: 700px) {
    .hero {
      min-height: unset;
      padding-block: var(--space-12);
    }

    .hero-container {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .hero-image-col {
      display: none;
    }

    .hero-cta {
      justify-content: flex-end;
    }
  }

  /* ─── Reduced motion ─────────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    /* Skip typewriter entirely — show plain H1, hide overlay */
    .hero-typewriter {
      display: none !important;
    }

    .hero-photo {
      transition: none;
    }

    .hero-caption-text.is-active::after {
      animation: none;
    }

    :global(.js) .hero-headline:not(.hero-typewriter) {
      position: static !important;
      inline-size: auto !important;
      block-size: auto !important;
      margin: 0 !important;
      overflow: visible !important;
      clip: auto !important;
      clip-path: none !important;
      white-space: normal !important;
    }

    .typewriter-target::after {
      animation: none;
    }
  }
</style>

<script>
  import { initializeCompanyTargeting } from '../../utils/companyTargeting';
  import { initializeHeroPhotoEasterEgg } from '../../utils/heroPhotoEasterEgg';
  import { initializeHeroTypewriter } from '../../utils/heroTypewriter';

  const company = initializeCompanyTargeting({
    window,
    document,
    applicantName: 'Afton Gauntlett',
  });

  const section = document.querySelector<HTMLElement>('.hero');
  const targetEl = document.querySelector<HTMLElement>('.typewriter-target');

  if (company && section && targetEl) {
    initializeHeroTypewriter({ window, section, targetEl });
  }

  // ── Photo easter egg ─────────────────────────────────────────────
  const imgWrap = document.getElementById('hero-img-wrap');
  const imgContainer = document.getElementById('hero-img-container');
  const captionEl = document.getElementById('hero-caption-text');

  if (
    imgWrap instanceof HTMLElement &&
    imgContainer instanceof HTMLElement &&
    captionEl instanceof HTMLElement
  ) {
    initializeHeroPhotoEasterEgg({ window, imgWrap, imgContainer, captionEl });
  }
</script>
