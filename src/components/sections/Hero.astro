---
import { APPLICANT, COMPANY } from '../../config/site';
import Button from '../ui/Button.astro';

// The placeholder is always the "joke" text the animation types first.
// Hardcoded so the gag works even when targetName is already the real company.
const PLACEHOLDER_NAME = 'Your Company';
---

<section id="top" class="hero" aria-label="Introduction">
  <div class="container hero-container">

    {/* ── Left: headshot ───────────────────────────────────────── */}
    <div class="hero-image-col" aria-hidden="true">
      <div class="hero-image-wrap" id="hero-img-wrap">
        <div class="hero-img-container" id="hero-img-container">
          <img
            src="/images/afton-headshot-v2.webp"
            alt="Afton Gauntlett professional headshot"
            class="hero-photo hero-photo--pro"
            loading="eager"
            decoding="async"
            draggable="false"
          />
          <img
            src="/images/little-afton.webp"
            alt="Young Afton, circa early-90s"
            class="hero-photo hero-photo--little"
            loading="lazy"
            decoding="async"
            draggable="false"
          />
        </div>
        <p class="hero-photo-caption">
          <span class="hero-caption-text" id="hero-caption-text"></span>
        </p>
      </div>
    </div>

    {/* ── Right: text content ──────────────────────────────────── */}
    <div class="hero-content">
      {/* Accessible, always-present H1 — screen reader source of truth */}
      <h1 class="hero-headline">Dear {COMPANY.targetName},</h1>

      {/* Visual typewriter overlay — aria-hidden, never read by AT */}
      <p class="hero-headline hero-typewriter" aria-hidden="true">
        Dear <span class="hero-bracket">[</span><span
          class="typewriter-target"
          data-target={COMPANY.targetName}
          data-placeholder={PLACEHOLDER_NAME}></span><span class="hero-bracket">]</span>,
      </p>

      {/*
        Inline patch script: runs synchronously before the bundled animation script fires.
        1. Reads ?to= param, saves to sessionStorage, strips param from URL (clean URL for recipient).
        2. On refresh (no param), falls back to sessionStorage.
        3. If neither has a value, redirects to /404.
        Uses .textContent (not .innerHTML) — safe from XSS.
      */}
      <script is:inline>
        (function () {
          const params = new URLSearchParams(window.location.search);
          let company = params.get('to');

          if (company) {
            // Save to sessionStorage so a page refresh still works.
            sessionStorage.setItem('dear-to', company);
          } else {
            // No param — check sessionStorage (covers the refresh case).
            company = sessionStorage.getItem('dear-to');
          }

          // Still nothing — not a personalised link, send to 404.
          // On localhost, skip the redirect and use a dev placeholder instead.
          if (!company) {
            if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
              company = 'Local Dev';
            } else {
              window.location.replace('/404');
              return;
            }
          }

          // Patch the accessible h1 (screen-reader source of truth)
          const headline = document.querySelector('.hero-headline');
          if (headline) headline.textContent = 'Dear ' + company + ',';

          // Patch data-target so the typewriter animation types the right name
          const typewriter = document.querySelector('[data-target]');
          if (typewriter) typewriter.setAttribute('data-target', company);

          // Patch the page title
          document.title = 'Dear ' + company + ' \u2014 Afton Gauntlett';
        })();
      </script>

      <p class="hero-subhead">
        I built this instead of recording a video. I think you&rsquo;ll agree it was the right
        call.
      </p>

      <div class="hero-cta">
        <Button href={`mailto:${APPLICANT.email}`}>Let&rsquo;s talk</Button>
        <Button href="#work" variant="outline">See my work ↓</Button>
      </div>
    </div>

  </div>

</section>

<style>
  /* ─── Section ────────────────────────────────────────────────── */

  .hero {
    position: relative;
    min-height: 70dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: var(--space-12);
  }

  /* ─── Two-column grid ────────────────────────────────────────── */

  .hero-container {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.35fr);
    gap: var(--space-16);
    align-items: center;
  }

  /* ─── Image column ───────────────────────────────────────────── */

  .hero-image-col {
    display: flex;
    justify-content: center;
  }

  /* ─── Headshot wrap + image swap ─────────────────────────────── */

  .hero-image-wrap {
    width: 100%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-img-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 2px 24px color-mix(in srgb, var(--tone-text) 10%, transparent);
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    transition: opacity 1.5s ease;
    user-select: none;
    -webkit-user-drag: none;
  }

  .hero-photo--pro {
    opacity: 1;
  }

  .hero-photo--little {
    opacity: 0;
  }

  .hero-img-container.is-little-afton .hero-photo--pro {
    opacity: 0;
  }

  .hero-img-container.is-little-afton .hero-photo--little {
    opacity: 1;
  }

  /* ─── Hover caption / easter-egg text ────────────────────────── */

  .hero-photo-caption {
    min-height: 5rem;
    font-size: 0.875rem;
    color: var(--tone-text-muted);
    line-height: 1.6;
    font-style: italic;
    text-align: center;
  }

  .hero-caption-text.is-active::after {
    content: '|';
    color: var(--tone-primary);
    animation: caption-caret-blink 0.7s step-end infinite;
  }

  @keyframes caption-caret-blink {
    50% {
      opacity: 0;
    }
  }

  /* ─── Content column ─────────────────────────────────────────── */

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* ─── Headline shared styles ─────────────────────────────────── */

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 4.4rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--tone-text);
    margin: 0;
  }

  /* ─── Typewriter overlay (default: hidden, no-JS safe) ───────── */

  .hero-typewriter {
    display: none;
  }

  /* ─── With JS: visually hide real H1, show overlay ───────────── */

  :global(.js) .hero-headline:not(.hero-typewriter) {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  :global(.js) .hero-typewriter {
    display: block;
  }

  /* ─── Bracket styling ────────────────────────────────────────── */

  .hero-bracket {
    color: var(--tone-text-muted);
  }

  /* ─── Typing caret ───────────────────────────────────────────── */

  .typewriter-target::after {
    content: '|';
    color: var(--tone-primary);
    animation: hero-caret-blink 0.7s step-end infinite;
  }

  @keyframes hero-caret-blink {
    50% {
      opacity: 0;
    }
  }

  /* ─── Subheadline ────────────────────────────────────────────── */

  .hero-subhead {
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    color: var(--tone-text-muted);
    max-width: 38rem;
    line-height: 1.65;
  }

  /* ─── CTA cluster ────────────────────────────────────────────── */

  .hero-cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
  }

  /* ─── Mobile: single column, image on top ────────────────────── */

  @media (max-width: 700px) {
    .hero {
      min-height: unset;
      padding-block: var(--space-12);
    }

    .hero-container {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .hero-image-col {
      display: none;
    }

    .hero-cta {
      justify-content: flex-end;
    }
  }

  /* ─── Reduced motion ─────────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    /* Skip typewriter entirely — show plain H1, hide overlay */
    .hero-typewriter {
      display: none !important;
    }

    .hero-photo {
      transition: none;
    }

    .hero-caption-text.is-active::after {
      animation: none;
    }

    :global(.js) .hero-headline:not(.hero-typewriter) {
      position: static !important;
      inline-size: auto !important;
      block-size: auto !important;
      margin: 0 !important;
      overflow: visible !important;
      clip: auto !important;
      clip-path: none !important;
      white-space: normal !important;
    }

    .hero-scroll-hint {
      animation: none;
    }

    .typewriter-target::after {
      animation: none;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('.hero');
  const targetEl = document.querySelector<HTMLElement>('.typewriter-target');

  if (section && targetEl) {
    const placeholder = targetEl.dataset.placeholder ?? 'Your Company';
    const finalTarget = targetEl.dataset.target ?? '';

    const markDone = (): void => {
      section.classList.add('hero--done');
    };

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // CSS handles this: overlay is hidden, real H1 is shown statically.
      // No JS needed — just don't start the animation.
    } else {
      const TYPE_SPEED = 70; // ms per character (typing)
      const ERASE_SPEED = 45; // ms per character (backspacing — slightly faster)
      const INITIAL_DELAY = 500; // ms before we start typing the joke name
      const PAUSE_ON_JOKE = 1400; // ms to hold "Your Company" before erasing

      const typeChars = (text: string, onDone: () => void): void => {
        let i = 0;
        const tick = (): void => {
          if (i < text.length) {
            targetEl.textContent = text.slice(0, ++i);
            setTimeout(tick, TYPE_SPEED);
          } else {
            onDone();
          }
        };
        tick();
      };

      const eraseChars = (onDone: () => void): void => {
        const tick = (): void => {
          const current = targetEl.textContent ?? '';
          if (current.length > 0) {
            targetEl.textContent = current.slice(0, -1);
            setTimeout(tick, ERASE_SPEED);
          } else {
            onDone();
          }
        };
        tick();
      };

      // Sequence: wait → type joke → pause → erase → type real name → done
      setTimeout(() => {
        typeChars(placeholder, () => {
          setTimeout(() => {
            eraseChars(() => {
              // Brief gap between erasing and re-typing feels natural
              setTimeout(() => {
                typeChars(finalTarget, markDone);
              }, 200);
            });
          }, PAUSE_ON_JOKE);
        });
      }, INITIAL_DELAY);
    }
  }

  // ── Photo easter egg ─────────────────────────────────────────────
  const imgWrap = document.getElementById('hero-img-wrap');
  const imgContainer = document.getElementById('hero-img-container');
  const captionEl = document.getElementById('hero-caption-text');

  if (
    imgWrap instanceof HTMLElement &&
    imgContainer instanceof HTMLElement &&
    captionEl instanceof HTMLElement &&
    !window.matchMedia('(prefers-reduced-motion: reduce)').matches
  ) {
    const PRO_CAPTION =
      'This is my super professional headshot that AI glamourized. Click the image 3 times to get a glimpse of my personality.';
    const LITTLE_CAPTION = "Still silly, just more professional now!";
    const TYPE_SPEED = 40;   // ms per char — typing
    const ERASE_SPEED = 18;  // ms per char — erasing (faster feels right)
    const EASTER_EGG_DURATION = 20_000; // ms before fading back to pro

    let timer: ReturnType<typeof setTimeout> | null = null;
    let isEasterEggActive = false;
    let isHovering = false;
    let clickCount = 0;
    let clickResetTimer: ReturnType<typeof setTimeout> | null = null;
    let fadeBackTimer: ReturnType<typeof setTimeout> | null = null;

    const stopTimer = (): void => {
      if (timer !== null) { clearTimeout(timer); timer = null; }
    };

    const typeText = (targetText: string, onDone?: () => void): void => {
      captionEl.classList.add('is-active');
      const tick = (): void => {
        const cur = captionEl.textContent ?? '';
        if (cur.length < targetText.length) {
          captionEl.textContent = targetText.slice(0, cur.length + 1);
          timer = setTimeout(tick, TYPE_SPEED);
        } else {
          onDone?.();
        }
      };
      tick();
    };

    const eraseText = (onDone?: () => void): void => {
      captionEl.classList.add('is-active');
      const tick = (): void => {
        const cur = captionEl.textContent ?? '';
        if (cur.length > 0) {
          captionEl.textContent = cur.slice(0, -1);
          timer = setTimeout(tick, ERASE_SPEED);
        } else {
          captionEl.classList.remove('is-active');
          onDone?.();
        }
      };
      tick();
    };

    imgWrap.addEventListener('mouseenter', () => {
      isHovering = true;
      if (isEasterEggActive) return;
      stopTimer();
      // If residual text doesn't match the start of PRO_CAPTION, clear it first
      const cur = captionEl.textContent ?? '';
      if (cur.length > 0 && !PRO_CAPTION.startsWith(cur)) {
        captionEl.textContent = '';
      }
      typeText(PRO_CAPTION);
    });

    imgWrap.addEventListener('mouseleave', () => {
      isHovering = false;
      if (isEasterEggActive) return;
      stopTimer();
      eraseText();
    });

    const returnToPro = (): void => {
      if (fadeBackTimer !== null) { clearTimeout(fadeBackTimer); fadeBackTimer = null; }
      imgContainer.classList.remove('is-little-afton');
      setTimeout(() => {
        stopTimer();
        eraseText(() => {
          isEasterEggActive = false;
          if (isHovering) typeText(PRO_CAPTION);
        });
      }, 800);
    };

    imgWrap.addEventListener('click', () => {
      // While little-afton is showing, triple-click returns to pro immediately
      if (isEasterEggActive) {
        clickCount++;
        if (clickResetTimer !== null) clearTimeout(clickResetTimer);
        clickResetTimer = setTimeout(() => { clickCount = 0; }, 2000);
        if (clickCount >= 3) {
          clickCount = 0;
          if (clickResetTimer !== null) { clearTimeout(clickResetTimer); clickResetTimer = null; }
          returnToPro();
        }
        return;
      }

      clickCount++;
      if (clickResetTimer !== null) clearTimeout(clickResetTimer);
      clickResetTimer = setTimeout(() => { clickCount = 0; }, 2000);

      if (clickCount >= 3) {
        clickCount = 0;
        if (clickResetTimer !== null) { clearTimeout(clickResetTimer); clickResetTimer = null; }
        isEasterEggActive = true;
        stopTimer();

        // Swap to little Afton
        imgContainer.classList.add('is-little-afton');

        // Type easter-egg caption
        captionEl.textContent = '';
        typeText(LITTLE_CAPTION);

        // Schedule auto fade back after timeout
        if (fadeBackTimer !== null) clearTimeout(fadeBackTimer);
        fadeBackTimer = setTimeout(returnToPro, EASTER_EGG_DURATION);
      }
    });
  }
</script>
