---
import Button from '../ui/Button.astro';
---

<section id="themes" class="section stack">
  <div>
    <p class="kicker">Theme Tokens</p>
    <h2>Design direction can change without rewriting components.</h2>
    <p>
      Each preview below uses the same component classes with different token values. No hard-coded
      component colors.
    </p>
  </div>

  <div class="theme-grid">
    <article class="theme-preview" data-theme="sprout" aria-label="Sprout theme preview">
      <p class="theme-name">Sprout</p>
      <h3>Warm and hopeful</h3>
      <p>Great for local groups, education, and care-oriented organizations.</p>
      <Button size="sm" type="button">Primary action</Button>
    </article>

    <article class="theme-preview" data-theme="ocean" aria-label="Ocean theme preview">
      <p class="theme-name">Ocean</p>
      <h3>Crisp and civic</h3>
      <p>Useful for policy explainers, reporting sites, and public resource hubs.</p>
      <Button size="sm" type="button">Primary action</Button>
    </article>

    <article class="theme-preview" data-theme="earth" aria-label="Earth theme preview">
      <p class="theme-name">Earth</p>
      <h3>Grounded and direct</h3>
      <p>Works well for neighborhood campaigns, food access, and mutual aid services.</p>
      <Button size="sm" type="button">Primary action</Button>
    </article>
  </div>
</section>
