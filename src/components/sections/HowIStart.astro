---
import SetupCard from '../ui/SetupCard.astro';
import { CircleCheckBig, FileCode, Bot, Paintbrush, ShieldCheck, GitMerge } from '@lucide/astro';
---

<section id="start" class="howisstart-section" aria-labelledby="start-heading">
  <div class="container">

    <div class="section-intro fade-up">
      <h2 id="start-heading">Before I write a line of code</h2>
      <p class="section-lead">
        My setup checklist runs before the first commit — whether I'm starting something new
        or joining an existing codebase.
      </p>
    </div>

    <div class="card-groups">

      <!-- Group 1: Every project -->
      <div class="card-group">
        <p class="group-label kicker">Every project</p>
        <div class="card-row card-row-3">
          <SetupCard title="Lint" icon={CircleCheckBig} class="fade-up">
            <p>Hard blocks, not warnings. If it can be caught statically, it gets caught before it ships.</p>
          </SetupCard>
          <SetupCard title="Typecheck" icon={FileCode} class="fade-up">
            <p>
              TypeScript strict mode throughout. I'd rather fight the compiler for ten minutes
              than debug a runtime null at 11pm.
            </p>
          </SetupCard>
          <SetupCard title="Agent rules" icon={Bot} class="fade-up">
            <p>
              Reusable components (theme tokens, accessibility, keyboard nav), defined in Copilot
              instructions and PRDs.
            </p>
          </SetupCard>
        </div>
      </div>

      <!-- Group 2: Team projects -->
      <div class="card-group">
        <p class="group-label kicker">Team projects</p>
        <div class="card-row card-row-3">
          <SetupCard title="Prettier + ESLint" icon={Paintbrush} class="fade-up">
            <p>
              Consistent formatting is about eliminating
              noisy format-diff PRs in code review so the actual logic gets the attention.
            </p>
          </SetupCard>
          <SetupCard title="Husky pre-commit hooks" icon={ShieldCheck} class="fade-up">
            <p>
              Everyone codes however they want. The hook cleans it before it hits the branch. No
              config policing, no "can you just run prettier" comments in review.
            </p>
          </SetupCard>
          <SetupCard title="Git hygiene" icon={GitMerge} class="fade-up">
            <p>
              Atomic commits, useful messages, rebase on main before the PR. I review MRs with
              actual feedback and don't panic at a merge conflict.
            </p>
          </SetupCard>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .howisstart-section {
    padding-block: var(--space-16);
  }

  .section-intro {
    display: grid;
    gap: var(--space-4);
    margin-block-end: var(--space-8);
  }

  .section-lead {
    color: var(--tone-text-muted);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    max-width: 64ch;
    line-height: 1.65;
  }

  .card-groups {
    display: grid;
    gap: var(--space-12);
  }

  .card-group {
    display: grid;
    gap: var(--space-4);
  }

  .group-label {
    margin: 0;
  }

  .card-row {
    display: grid;
    gap: var(--space-4);
    align-items: stretch;
  }

  .card-row-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  /* SetupCard hover is self-contained — no overrides needed here */

  @media (max-width: 920px) {
    .card-row-3 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .card-row-3 {
      grid-template-columns: 1fr;
    }
  }
</style>
