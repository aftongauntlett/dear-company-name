---
/**
 * HowIWork — replaces the "Recent Work" section.
 *
 * Shows the source code of *this* page via the CodeExplorer.
 * The explorer is heavy HTML, so it uses a three-phase lazy-loading strategy:
 *
 *   1. Page loads — explorer is in the DOM with `content-visibility: hidden`
 *      (browser parses but does NOT paint/layout it — free for scroll performance).
 *   2. User scrolls to section — IntersectionObserver fires, we flip
 *      content-visibility to `visible`, which triggers browser layout/paint.
 *   3. `requestIdleCallback` fires when the browser goes idle after painting.
 *      Only then do we fade the Lottie out and the explorer in — so the cat
 *      plays for the actual duration of real browser work, not an artificial timer.
 */

import CodeExplorer from './CodeExplorer.astro';
import Button from '../ui/Button.astro';
import { CODE_VIEWS, HIGHLIGHTED_FILES } from '../../config/codeViews';
import {
  fetchRepoTree,
  fetchFileContent,
  filterTreeByWhitelist,
  detectLanguage,
  type ResolvedFile,
  type ResolvedView,
} from '../../utils/github';

const primaryView = CODE_VIEWS[0];
const githubUrl = primaryView
  ? `https://github.com/${primaryView.owner}/${primaryView.repo}`
  : 'https://github.com';

const token = import.meta.env.GITHUB_TOKEN as string | undefined;
let resolvedView: ResolvedView | null = null;
let highlightedPaths: string[] = [];
let explorerLoadFailed = false;

try {
  // ── Fetch all repo trees ────────────────────────────────────────────────
  const viewsWithTrees = await Promise.all(
    CODE_VIEWS.map(async (view) => {
      const ref = view.ref ?? 'main';
      const tree = await fetchRepoTree(view.owner, view.repo, ref, token);
      const filteredEntries = filterTreeByWhitelist(tree, view.include);
      return { view, ref, entries: filteredEntries };
    }),
  );

  // ── Fetch file content — highlighting is done at render time by <Code /> ──
  const resolvedViews: ResolvedView[] = await Promise.all(
    viewsWithTrees.map(async ({ view, ref, entries }) => {
      const files = await Promise.all(
        entries.map(async (entry): Promise<ResolvedFile | null> => {
          const content = await fetchFileContent(
            view.owner,
            view.repo,
            entry.path,
            ref,
            token,
          );
          if (content === null) return null;

          return { path: entry.path, content, language: detectLanguage(entry.path) };
        }),
      );

      return {
        view,
        files: files.filter((f): f is ResolvedFile => f !== null),
        tree: entries,
      };
    }),
  );

  resolvedView = resolvedViews[0] ?? null;
  highlightedPaths = HIGHLIGHTED_FILES.map((h) => h.path);
} catch (error) {
  explorerLoadFailed = true;
  console.error('[HowIWork] Explorer data unavailable; rendering fallback.', error);
}
---

<section id="how-i-work" class="howiwork-section fade-up" aria-labelledby="howiwork-heading">
  <div class="container">

    <div class="section-intro">
      <h2 id="howiwork-heading">How I work</h2>
      <p class="section-lead">
      You're looking at it! This page is the project and the explorer below is a peek under the hood. 
      </p>
    </div>

    <!-- ── Tech stack chips ──────────────────────────────────────────── -->
    <div class="stack-strip" aria-label="Tech stack used on this project">
      <span class="stack-strip-label">Built with</span>
      <ul class="chip-list" role="list">
        {[
          'Astro', 'TypeScript',
          'Vercel', 'Lucide', 'Vitest', 
          'Shiki',
          'ESLint', 'CSS Tokens', 'GitHub API', 'Lottie',
        ].map((tech) => (
          <li class="chip">{tech}</li>
        ))}
      </ul>
    </div>

    <!-- ── File annotations: spotlight on highlighted files ─────────── -->
    <div class="file-highlights" aria-label="Notable files">
      <h3 class="highlights-heading">Files worth reading</h3>
      <ul class="highlights-list" role="list">
        {
          HIGHLIGHTED_FILES.map(({ path, note }) => (
            <li class="highlight-card">
              <div class="highlight-card-header">
                <span class="highlight-star" aria-hidden="true">&#9733;</span>
                <code class="highlight-path">{path}</code>
              </div>
              <p class="highlight-note" set:html={note} />
            </li>
          ))
        }
      </ul>
    </div>

    <!--
      ── Lazy-loading gate ──────────────────────────────────────────────
      The explorer content is in the DOM but hidden via content-visibility.
      The spinner placeholder is hidden by default, only shown if rendering
      takes longer than ~300ms, then fades out once the browser goes idle.
    -->
    {
      explorerLoadFailed || !resolvedView ? (
        <div class="explorer-unavailable" role="status" aria-live="polite">
          <p class="explorer-unavailable-title">Temporary issue loading the code explorer.</p>
          <p class="explorer-unavailable-body">
            GitHub is currently unavailable or rate-limited. Everything else on this page is still
            available.
          </p>
        </div>
      ) : (
        <div class="explorer-gate" id="explorer-gate">

          <div
            class="explorer-placeholder"
            id="explorer-placeholder"
            hidden
            aria-hidden="true"
          >
            <div class="placeholder-spinner" aria-hidden="true"></div>
            <p class="placeholder-label" aria-hidden="true">Loading…</p>
          </div>

          <div class="explorer-content" id="explorer-content" aria-hidden="true">
            <CodeExplorer view={resolvedView} highlighted={highlightedPaths} />
          </div>

        </div>
      )
    }

    <div class="explorer-actions">
      <Button
        href={githubUrl}
        variant="outline"
        size="sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        View on GitHub →
      </Button>
    </div>

  </div>
</section>

<script>
  const gate = document.getElementById('explorer-gate');
  const placeholder = document.getElementById('explorer-placeholder') as HTMLElement | null;
  const content = document.getElementById('explorer-content');

  if (!gate || !placeholder || !content) {
    content?.removeAttribute('aria-hidden');
  } else {
    // Threshold: show Lottie only if render hasn't finished by this point.
    // Below ~300ms users don't perceive a delay — no indicator needed.
    // At 300ms they first notice "something is happening" — that's the right
    // moment for the cat to appear and say "yes, I know, loading."
    const SLOW_THRESHOLD_MS = 300;
    const FADE_MS = 350;

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries[0]?.isIntersecting) return;
        observer.disconnect();

        // Start rendering — browser begins layout/paint now
        content.classList.add('is-rendering');

        let didShowLottie = false;

        // If still not done after threshold, reveal the Lottie overlay
        const slowTimer = setTimeout(() => {
          didShowLottie = true;
          placeholder.hidden = false;
          placeholder.setAttribute('role', 'status');
          placeholder.setAttribute('aria-label', 'Loading code explorer');
          // rAF so the browser registers `hidden = false` before adding the class
          requestAnimationFrame(() => placeholder.classList.add('is-visible'));
        }, SLOW_THRESHOLD_MS);

        const onIdle = () => {
          clearTimeout(slowTimer);

          // Reveal explorer
          content.classList.add('is-visible');
          content.removeAttribute('aria-hidden');

          if (didShowLottie) {
            // Fade Lottie out, then clean up
            placeholder.classList.remove('is-visible');
            placeholder.classList.add('is-done');
            setTimeout(() => {
              placeholder.hidden = true;
              placeholder.removeAttribute('role');
              document.dispatchEvent(new CustomEvent('lottie:stop'));
            }, FADE_MS);
          }
        };

        if ('requestIdleCallback' in window) {
          requestIdleCallback(onIdle, { timeout: 2500 });
        } else {
          requestAnimationFrame(() => requestAnimationFrame(onIdle));
        }
      },
      { threshold: 0.05 },
    );

    observer.observe(gate);
  }

</script>

<style>
  .howiwork-section {
    padding-block: var(--space-16);
    background-color: var(--tone-bg);
  }

  .section-intro {
    display: grid;
    gap: var(--space-4);
    margin-block-end: var(--space-6);
  }

  .section-lead {
    color: var(--tone-text-muted);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    max-width: 64ch;
    line-height: 1.65;
  }

  .star-accent {
    color: var(--tone-primary);
  }

  /* ── Tech stack chip strip ─────────────────────────────────── */
  .stack-strip {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-block-end: var(--space-8);
  }

  .stack-strip-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--tone-text-muted);
    white-space: nowrap;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1;
    padding: 0.3em 0.7em;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--tone-primary) 10%, transparent);
    color: var(--tone-primary-hover);
    border: 1px solid color-mix(in srgb, var(--tone-primary) 25%, transparent);
  }

  /* ── Gate: position:relative so the overlay can anchor to it ── */
  .explorer-gate {
    position: relative;
    margin-block-start: var(--space-8);
  }

  /* ── Placeholder: absolute overlay — never adds height ──────── */
  /* hidden by default; JS reveals it only after the slow threshold */
  .explorer-placeholder {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    border: 1px solid var(--tone-border);
    border-radius: var(--radius-md);
    background: var(--tone-surface);
    opacity: 0;
    transition: opacity 200ms ease;
    pointer-events: none;
  }

  .explorer-placeholder.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .explorer-placeholder.is-done {
    opacity: 0;
    pointer-events: none;
  }

  .placeholder-spinner {
    width: 2rem;
    height: 2rem;
    border: 2px solid var(--tone-border);
    border-top-color: var(--tone-primary);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .explorer-unavailable {
    margin-block-start: var(--space-8);
    border: 1px solid var(--tone-border);
    border-radius: var(--radius-md);
    background: var(--tone-surface);
    padding: var(--space-8);
    display: grid;
    justify-items: center;
    text-align: center;
    gap: var(--space-4);
  }

  .explorer-unavailable-title {
    margin: 0;
    font-weight: 700;
    color: var(--tone-text);
  }

  .explorer-unavailable-body {
    margin: 0;
    max-width: 48ch;
    color: var(--tone-text-muted);
    line-height: 1.6;
  }

  .placeholder-label {
    color: var(--tone-text-muted);
    font-size: 0.875rem;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  /* ── Explorer content: deferred until in-view ───────────────── */
  .explorer-content {
    content-visibility: hidden;
    contain-intrinsic-size: 0 640px;
    opacity: 0;
    transition: opacity 350ms ease;
  }

  /* Phase 2: browser is rendering it (not yet visible) */
  .explorer-content.is-rendering {
    content-visibility: visible;
  }

  /* Phase 3: browser idle — fade in */
  .explorer-content.is-visible {
    opacity: 1;
  }

  /* ── GitHub link below explorer ──────────────────────────── */
  .explorer-actions {
    display: flex;
    justify-content: center;
    margin-block-start: var(--space-6);
  }

  /* ── File highlights: annotation cards below explorer ──────── */
  .file-highlights {
    margin-block-start: var(--space-12);
  }

  .highlights-heading {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.4vw, 1.3rem);
    font-weight: 700;
    color: var(--tone-text-muted);
    margin-block-end: var(--space-6);
    letter-spacing: -0.01em;
  }

  .highlights-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 28rem), 1fr));
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .highlight-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--tone-card);
    border: 1px solid var(--tone-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-surface);
    transition: border-color 180ms ease;
  }

  .highlight-card:hover {
    border-color: color-mix(in srgb, var(--tone-primary) 40%, var(--tone-border));
  }

  @media (prefers-reduced-motion: no-preference) {
    .highlight-card:hover .highlight-star {
      animation: wiggle 0.5s ease-in-out;
    }
  }

  .highlight-card-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .highlight-star {
    font-size: 0.85rem;
    color: var(--tone-primary);
    flex-shrink: 0;
    line-height: 1;
  }

  .highlight-path {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--tone-primary);
    word-break: break-all;
    line-height: 1.4;
  }

  .highlight-note {
    color: var(--tone-text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
    margin: 0;
  }

  .highlight-note :global(code) {
    font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
    font-size: 0.875em;
    color: var(--tone-primary-hover);
    background: color-mix(in srgb, var(--tone-primary) 12%, transparent);
    border-radius: var(--radius-sm);
    padding: 0.1em 0.35em;
  }
</style>
