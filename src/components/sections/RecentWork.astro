---
import ProjectCard from '../ui/ProjectCard.astro';
---

<section id="work" class="recentwork-section" aria-labelledby="work-heading">
  <div class="container">

    <div class="section-intro">
      <h2 id="work-heading">Recent work</h2>
      <p class="section-lead">A range of real constraints, real clients, and one that&rsquo;s just for fun.</p>
    </div>

    <div class="work-grid">

      <ProjectCard
        title="Ghostbusters Virginia"
        eyebrow="Nonprofit rebuild"
        tech={['Astro', 'TypeScript', 'React Islands', 'Markdoc', 'Vercel']}
        liveHref="https://gbva-site.vercel.app/"
        repoHref="https://github.com/ghostbustersvirginia/ghostbustersva"
      >
        <p>
          Full rebuild of a fan-run nonprofit&rsquo;s community site from WordPress to static Astro.
          Event calendar with countdowns, a five-step appearance request wizard with
          sessionStorage-backed state, an SVG donation gauge with geometry computed server-side,
          and an LED scrollbar published as its own npm package. React islands only where genuine
          interactivity was needed. Accessibility factored in from the start &mdash; focus trapping,
          <code>aria-describedby</code> on error messages, full keyboard nav throughout.
        </p>
      </ProjectCard>

      <ProjectCard
        title="NPC Finder"
        eyebrow="Personal project · In development"
        tech={['React 19', 'TypeScript', 'TanStack Query', 'Supabase', 'Framer Motion']}
        liveHref="https://npcfinder.com/"
        repoHref="https://github.com/aftongauntlett/npcfinder"
      >
        <p>
          An invite-only social utility &mdash; somewhere between a private media tracker and a
          shared home base. Kanban boards, recipe tracker, job tracker, customizable profiles.
          The security foundation is PostgreSQL Row Level Security enforcing data isolation at
          the database layer, not application code &mdash; with role-based access, rate limiting
          baked into the schema, edge functions for elevated writes, and explicit SSRF protection
          on the scrape-url endpoint.
        </p>
      </ProjectCard>

      <ProjectCard
        title="no-wb.org"
        eyebrow="Side project"
        tech={['Astro', 'TypeScript', 'Tailwind CSS', 'Vercel']}
        liveHref="https://no-wb.org/"
        repoHref="https://github.com/aftongauntlett/no-whiteboard-jobs-dashboard"
      >
        <p>
          A frontend dashboard built on the Hiring Without Whiteboards open dataset &mdash; turning
          a large markdown list into a fast, searchable web experience. Full-text search,
          multi-filtering, card and list view modes, pagination, dark and light themes,
          mobile-first navigation. Deliberately scoped: one dataset, one purpose, one week of
          focused work. Shipped and actively used by developers who&rsquo;d rather prove their
          skills by building things.
        </p>
      </ProjectCard>

      <ProjectCard
        title="Orbital Order"
        eyebrow="Constraint-driven game dev"
        tech={['JavaScript', 'Canvas 2D', 'Web Audio API', '13kb limit']}
        liveHref="https://orbital-order.aftongauntlett.com/"
        liveLabel="Play game"
        repoHref="https://github.com/aftongauntlett/js13k-demo"
      >
        <p>
          JS13k game jam entry &mdash; the entire submission must fit in 13 kilobytes. No
          frameworks, no libraries, no exceptions. A physics-based puzzle where you guide electrons
          into atomic orbitals using electromagnetic attraction and repulsion. Pure platform APIs,
          tight mechanics, creative compression. I enter because the constraints are genuinely fun
          and because shipping in 13kb keeps you honest about what code actually needs to exist.
        </p>
      </ProjectCard>

    </div>
  </div>
</section>

<style>
  .recentwork-section {
    padding-block: var(--space-16);
  }

  .section-intro {
    display: grid;
    gap: var(--space-4);
    margin-block-end: var(--space-8);
  }

  .section-lead {
    color: var(--tone-text-muted);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    max-width: 64ch;
    line-height: 1.65;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
    align-items: stretch;
  }

  @media (max-width: 640px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
