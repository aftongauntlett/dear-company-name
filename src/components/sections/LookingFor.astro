---
import { APPLICANT } from '../../config/site';
import BrandIcon from '../ui/BrandIcon.astro';
import Icon from '../ui/Icon.astro';
import { Globe, FileText, Phone, Mail, MapPin, ExternalLink } from '@lucide/astro';
---

<section id="looking-for" class="lookingfor-section fade-up" aria-labelledby="looking-for-heading">
  <div class="container">

    <h2 id="looking-for-heading">What I'm looking for</h2>

    <div class="lookingfor-cols">

      <div class="lookingfor-col-left">
        <div class="lookingfor-body">
          <p>
            Async-friendly teams that trust engineers to manage their own time. A design bar that
            people actually care about — not just "it works on mobile." Work that
            has a point to it, even if that point is just making a useful thing really well.
          </p>
          <p>
            Fast-moving without being chaotic: opinionated enough to make decisions, humble enough to
            revisit them. I want to work somewhere that treats accessibility and code quality as
            defaults, not debt to pay down later.
          </p>
        </div>
      </div>

      <div class="lookingfor-col-right">
        <div class="contact-header">
          <h3 class="videonote-heading">Reach me directly</h3>
          <div class="videonote-rule" aria-hidden="true"></div>
        </div>

        <ul class="contact-chips" role="list">
          <li>
            <a href={APPLICANT.github} target="_blank" rel="noopener noreferrer" class="chip chip-link">
              <BrandIcon name="github" size={14} />
              <span>GitHub</span>
              <span class="chip-external-indicator" aria-hidden="true">
                <Icon icon={ExternalLink} size={11} />
              </span>
            </a>
          </li>
          <li>
            <a href={APPLICANT.linkedin} target="_blank" rel="noopener noreferrer" class="chip chip-link">
              <BrandIcon name="linkedin" size={14} />
              <span>LinkedIn</span>
              <span class="chip-external-indicator" aria-hidden="true">
                <Icon icon={ExternalLink} size={11} />
              </span>
            </a>
          </li>
          <li>
            <a href={APPLICANT.website} target="_blank" rel="noopener noreferrer" class="chip chip-link">
              <Icon icon={Globe} size={14} />
              <span>Portfolio</span>
              <span class="chip-external-indicator" aria-hidden="true">
                <Icon icon={ExternalLink} size={11} />
              </span>
            </a>
          </li>
          <li>
            <a href={APPLICANT.resume} target="_blank" rel="noopener noreferrer" class="chip chip-link">
              <Icon icon={FileText} size={14} />
              <span>Resume</span>
              <span class="chip-external-indicator" aria-hidden="true">
                <Icon icon={ExternalLink} size={11} />
              </span>
            </a>
          </li>
          <li>
            <a href={`mailto:${APPLICANT.email}`} class="chip chip-link">
              <Icon icon={Mail} size={14} />
              <span>{APPLICANT.email}</span>
            </a>
          </li>
          {APPLICANT.phone && (
            <li>
              <a href={`tel:${APPLICANT.phone.replace(/\D/g, '')}`} class="chip chip-link">
                <Icon icon={Phone} size={14} />
                <span>{APPLICANT.phone}</span>
              </a>
            </li>
          )}
          <li>
            <span class="chip chip-static">
              <Icon icon={MapPin} size={14} />
              <span>East Coast — night owl, can flex to other time zones</span>
            </span>
          </li>
        </ul>
      </div>

    </div>

  </div>
</section>

<style>
  .lookingfor-section {
    padding-block: var(--space-16);
  }

  .lookingfor-section h2 {
    margin-block-end: var(--space-8);
  }

  .lookingfor-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: stretch;
  }

  .lookingfor-col-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .lookingfor-col-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .lookingfor-body {
    grid-column: 1 / -1;
  }

  .lookingfor-body {
    display: grid;
    gap: var(--space-6);
    border-left: 4px solid var(--tone-primary);
    padding-inline-start: var(--space-8);
  }

  .lookingfor-body p {
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    line-height: 1.75;
    color: var(--tone-text);
    margin: 0;
  }

  .contact-header .videonote-heading {
    margin: 0 0 var(--space-2);
  }

  /* ── Chips ────────────────────────────────────────────────── */

  .contact-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--tone-border);
    background: color-mix(in srgb, var(--tone-surface-strong) 60%, transparent);
    color: var(--tone-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition:
      color 140ms ease,
      border-color 140ms ease,
      background 140ms ease;
  }

  .chip-link:hover {
    color: var(--tone-primary);
    border-color: color-mix(in srgb, var(--tone-primary) 50%, var(--tone-border));
    background: color-mix(in srgb, var(--tone-primary) 8%, var(--tone-surface));
  }

  .chip-link:focus-visible {
    outline: 2px solid var(--tone-ring);
    outline-offset: 2px;
  }

  .chip-external-indicator {
    display: inline-flex;
    align-items: center;
    max-width: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(1px);
    transition:
      max-width 140ms ease,
      opacity 140ms ease,
      transform 140ms ease;
  }

  .chip-link[target='_blank']:hover .chip-external-indicator,
  .chip-link[target='_blank']:focus-visible .chip-external-indicator {
    max-width: 1rem;
    opacity: 0.95;
    transform: translateY(0);
  }

  .chip-static {
    cursor: default;
    white-space: normal;
  }

  /* ── Video note / contact header ─────────────────────────── */

  .videonote-rule {
    border-top: 1px solid var(--tone-border);
    opacity: 0.5;
  }

  .videonote-heading {
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    font-weight: 600;
    color: var(--tone-text-muted);
    margin: 0;
  }

  @media (max-width: 720px) {
    .lookingfor-cols {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .lookingfor-body {
      border-left: none;
      border-top: 4px solid var(--tone-primary);
      padding-inline-start: 0;
      padding-block-start: var(--space-6);
    }

    .contact-header {
      text-align: center;
    }

    .contact-chips {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chip-external-indicator {
      transition: none;
    }
  }
</style>
