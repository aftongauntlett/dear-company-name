---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APPLICANT, COMPANY } from '../config/site';
import Hero from '../components/sections/Hero.astro';
import HowIStart from '../components/sections/HowIStart.astro';
import HowIChooseStack from '../components/sections/HowIChooseStack.astro';
import RecentWork from '../components/sections/RecentWork.astro';
import TeamLevels from '../components/sections/TeamLevels.astro';
import LookingFor from '../components/sections/LookingFor.astro';
---

<BaseLayout
  title={`Dear ${COMPANY.targetName} — ${APPLICANT.name}`}
  description={`A personal application from ${APPLICANT.name}, ${APPLICANT.title}.`}
>
  <Hero />
  <HowIStart />
  <HowIChooseStack />
  <RecentWork />
  <TeamLevels />
  <LookingFor />
</BaseLayout>

