---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APPLICANT, COMPANY } from '../config/site';
import Hero from '../components/sections/Hero.astro';
import HowIStart from '../components/sections/HowIStart.astro';
import HowIChooseStack from '../components/sections/HowIChooseStack.astro';
---

<BaseLayout
  title={`Dear ${COMPANY.targetName} — ${APPLICANT.name}`}
  description={`A personal application from ${APPLICANT.name}, ${APPLICANT.title}.`}
>
  <Hero />
  <HowIStart />
  <HowIChooseStack />
  <!-- Sections added in PRD-04 through PRD-05 -->
</BaseLayout>

